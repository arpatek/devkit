# =============================================================================
# secrets.env.example — devkit service credentials template
#
# Copy to config/secrets.env and fill in real values.
# This file is committed. secrets.env is gitignored.
#
# Load order: values already set in the environment take precedence over
# values in this file — real env vars always win.
# =============================================================================

# ──[ Proxmox ]─────────────────────────────────────────────────────────────────
# API token created in Proxmox UI: Datacenter > Permissions > API Tokens
# Privilege Separation OFF: token inherits the user's existing permissions.
# Privilege Separation ON: token has zero permissions until you assign roles
#   separately: Datacenter > Permissions > Add > API Token Permission
#   Path /, token user@pam!devkit, role PVEVMAdmin — repeat for PVEAuditor.
PROXMOX_HOST=blackwall.home.arpa
PROXMOX_USER=sysadmin@pam
PROXMOX_TOKEN_ID=devkit
PROXMOX_TOKEN_SECRET=

# ──[ Pi-hole ]─────────────────────────────────────────────────────────────────
# Admin password for Pi-hole v6 API session auth
PIHOLE_HOST=netrunner.home.arpa
PIHOLE_PASSWORD=

# ──[ Gitea ]───────────────────────────────────────────────────────────────────
# Personal access token: Gitea > Settings > Applications
# Read-only scopes are sufficient (repo, runner visibility)
GITEA_HOST=soulkiller.home.arpa
GITEA_PORT=3000
GITEA_USER=arpatek
GITEA_TOKEN=

# ──[ FreeIPA ]─────────────────────────────────────────────────────────────────
# Admin credentials for IPA XML-RPC session auth
# No Kerberos setup required on the local machine
IPA_HOST=mikoshi.home.arpa
IPA_USER=admin
IPA_PASSWORD=

# ──[ Monitoring ]──────────────────────────────────────────────────────────────
# No credentials needed — Prometheus and Grafana are open on the internal LAN
PROMETHEUS_HOST=netwatch.home.arpa
PROMETHEUS_PORT=9090
GRAFANA_HOST=netwatch.home.arpa
GRAFANA_PORT=3000
